# LLM via Amzur LiteLLM proxy
LITELLM_PROXY_URL=
LITELLM_VIRTUAL_KEY=
LITELLM_MODEL=
LITELLM_TEMPERATURE=0.7
LITELLM_MAX_TOKENS=2048

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# App
DEBUG=false
HOST=0.0.0.0
PORT=8000
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
GOOGLE_FRONTEND_CALLBACK_PATH=/auth/google/callback
# Optional. Keep empty to allow any email domain.
EMPLOYEE_EMAIL_DOMAIN=
AUTH_SECRET_KEY=
AUTH_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
