# Optional: override the API base URL.
# Leave empty to let the Vite dev-server proxy handle /api requests.
VITE_API_BASE_URL=

# Preferred local names
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Aliases read by Vite/frontend
VITE_SUPABASE_URL=${SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
VITE_SUPABASE_KEY=${SUPABASE_ANON_KEY}
